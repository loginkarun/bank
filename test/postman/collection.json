{
  "info": {
    "name": "Shopping Cart API Test Collection",
    "description": "Comprehensive API test collection for Shopping Cart Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "{{baseUrl}}",
