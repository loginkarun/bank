      "name": "3. Edge Cases & Boundary Tests",
      "item": [
        {
          "name": "3.1 Get Empty Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test Case ID: TC-CART-EDGE-001",
                  "// Scenario: Get cart for new user (empty cart)",
                  "// Expected: 200 OK with empty items array",
                  "",
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Cart is empty\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.items).to.be.an('array');",
                  "    pm.expect(jsonData.items.length).to.equal(0);",
                  "});",
                  "",
                  "pm.test(\"Total price is zero\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.totalPrice).to.equal(0.0);",
