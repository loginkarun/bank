    {
      "name": "1. Positive Tests - Happy Path",
      "item": [
        {
          "name": "1.1 Add Item to Cart - First Time",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test Case ID: TC-CART-001",
                  "// Scenario: Add a new product to empty cart",
                  "// Expected: 201 Created, item added with correct details",
                  "",
                  "pm.test(\"Status code is 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response has correct structure\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('items');",
                  "    pm.expect(jsonData).to.have.property('totalPrice');",
                  "});",
                  "",
                  "pm.test(\"Item added to cart successfully\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.items).to.be.an('array');",
                  "    pm.expect(jsonData.items.length).to.be.at.least(1);",
                  "});",
                  "",
                  "pm.test(\"Item has correct properties\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var item = jsonData.items[0];",
                  "    pm.expect(item).to.have.property('productId');",
                  "    pm.expect(item).to.have.property('name');",
                  "    pm.expect(item).to.have.property('price');",
                  "    pm.expect(item).to.have.property('quantity');",
                  "});",
                  "",
                  "pm.test(\"Total price calculated correctly\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var item = jsonData.items[0];",
                  "    var expectedTotal = item.price * item.quantity;",
                  "    pm.expect(jsonData.totalPrice).to.equal(expectedTotal);",
                  "});",
                  "",
                  "pm.test(\"Response time is less than 500ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});",
                  "",
                  "// Save productId for subsequent tests",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.items && jsonData.items.length > 0) {",
                  "    pm.collectionVariables.set('productId', jsonData.items[0].productId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{userId}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"productId\": 1,\n    \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cart/add",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "add"]
            },
            "description": "Add a product to the cart for the first time. Should create cart item with quantity 2."
          },
          "response": []
